# ===== LLM providers =====
# 至少配置一个
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 默认主路 / 快路 模型 (LiteLLM 模型字符串)
CHATASSISTANT_MODEL_PRIMARY=claude-sonnet-4-6
CHATASSISTANT_MODEL_FAST=claude-haiku-4-5-20251001

# ===== 本地数据库 =====
# SQLCipher 主密钥 (32 字节 hex)。生产环境会从 Windows DPAPI 取，本地开发可直接写
CHATASSISTANT_DB_KEY=

# ===== 服务 =====
CHATASSISTANT_HOST=127.0.0.1
CHATASSISTANT_PORT=8000

# ===== 隐私 =====
# 是否在脱敏失败时硬失败（推荐 true，prod 必须 true）
CHATASSISTANT_REDACT_STRICT=true
